# Dependencies
node_modules/

# Build output
dist/
dist-ssr/
src-tauri/target/

# Per-release updater manifest — generated at release time, published to the
# public releases repo (bklim5/devtools-releases), never committed to source.
/latest.json

# Logs
logs/
*.log
npm-debug.log*
pnpm-debug.log*

# OS / editor
.DS_Store
*.local

# E2E / UI-gate runtime artifacts (regenerated by scripts/e2e-spike.sh and the
# fallback DOM driver) — screenshots and tauri-dev logs are not source.
test/e2e/__screenshots__/
test/e2e/__logs__/

# Local Claude Code session dir + swept-in sibling tooling (not part of this project)
.claude/
.agents/
skills-lock.json

# Secrets (D-05) — minisign updater private key + password, Apple notary
# credentials. These are LOCAL gitignored env only; never committed. The
# minisign PUBLIC key lives in tauri.conf.json (it is public by design).
.env
.env.*
.envrc
*.key
*.p8

# Keygen CE local instance (D-41) — real secrets + the local Caddy CA stay
# local-only. The .env.example TEMPLATE is committed (re-included below; the
# global `.env.*` pattern above would otherwise swallow it).
scripts/keygen-ce/.env
scripts/keygen-ce/caddy-root.crt
!scripts/keygen-ce/.env.example
scripts/keygen-ce/spike-transcript.log
