{
  "name": "devtools",
  "private": true,
  "version": "0.2.1",
  "type": "module",
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "lint": "eslint .",
    "release:bump": "tsx scripts/bump-and-tag.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "lefthook install",
    "e2e": "wdio run wdio.conf.ts",
    "tauri:dev:e2e": "tauri dev --features webdriver"
  },
  "dependencies": {
    "@fontsource/ibm-plex-sans": "5.2.8",
    "@fontsource/jetbrains-mono": "5.2.8",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "2.3.2",
    "@tauri-apps/plugin-global-shortcut": "2.3.2",
    "@tauri-apps/plugin-process": "2.3.1",
    "@tauri-apps/plugin-store": "2.4.3",
    "@tauri-apps/plugin-updater": "2.10.1",
    "js-md5": "0.8.3",
    "lucide-react": "1.17.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "7.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "4.3.0",
    "@tauri-apps/cli": "^2",
    "@testing-library/react": "16.3.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@wdio/cli": "^9.27.2",
    "@wdio/local-runner": "^9.27.2",
    "@wdio/mocha-framework": "^9.27.2",
    "@wdio/spec-reporter": "9.27.2",
    "eslint": "10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "29.1.1",
    "lefthook": "2.1.9",
    "prettier": "3.8.3",
    "tailwindcss": "4.3.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^7.0.4",
    "vitest": "4.1.7",
    "webdriverio": "9.27.2"
  }
}
