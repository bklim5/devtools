{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Finding 8 (T-20-13): the webview app sees NO ambient @types — the
       server/webhook workspace member hoists @types/node, which would otherwise
       leak Node globals (process, Buffer, NodeJS.Timeout) into this `tsc --noEmit`
       gate and MASK browser-only type errors (e.g. setTimeout typed as
       NodeJS.Timeout instead of the DOM `number`). Node types stay scoped to
       server/webhook/tsconfig.json (`"types": ["node"]`). Do NOT re-add @types/node here. */
    "types": [],

    /* Path alias — must mirror vite.config.ts resolve.alias so `tsc --noEmit`
       (the unit gate) resolves the ported lib's `@/...` imports (FND-03). */
    "baseUrl": ".",
    "paths": { "@/*": ["./src/*"] },

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"],
  /* NOTE: server/webhook is deliberately NOT a project reference here. The gate
     typechecks it via an EXPLICIT second invocation in lefthook.yml
     (`tsc --noEmit -p server/webhook/tsconfig.json`) — D-56. A composite
     reference would force `noEmit:false` on the server config (TS6310) and is
     not needed, since the root gate runs `tsc --noEmit` without `--build`. */
  "references": [{ "path": "./tsconfig.node.json" }]
}
