# Production Keygen CE environment — TEMPLATE ONLY (D-41/D-50).
#
# Copy to `infra/keygen/.env` ON THE BOX and replace every "$(...)" with the
# output of that command. The real .env is gitignored and must NEVER be
# committed — it holds SECRET_KEY_BASE + the ENCRYPTION_* keys.
#
#   cd infra/keygen && cp .env.example .env   # then fill in the values
#
# This is the CE container's OWN env (web/worker/setup/caddy). The webhook
# service reads a SEPARATE file: server/webhook/.env (see that .env.example).
#
# Variable names are verbatim from keygen-api's .env.sample.

POSTGRES_USER=keygen
POSTGRES_PASSWORD="$(openssl rand -hex 16)"
POSTGRES_DB=keygen

REDIS_URL=redis://redis:6379

# --- CE secrets — generate with openssl, NEVER commit ---
SECRET_KEY_BASE="$(openssl rand -hex 64)"
ENCRYPTION_DETERMINISTIC_KEY="$(openssl rand -base64 32)"
ENCRYPTION_PRIMARY_KEY="$(openssl rand -base64 32)"
ENCRYPTION_KEY_DERIVATION_SALT="$(openssl rand -base64 32)"

KEYGEN_EDITION=CE
KEYGEN_MODE=singleplayer

# Fresh production account id (D-51) — MUST be lowercase. setup.sh / rails
# keygen:setup mints/uses the account under this id; the SAME value goes into
# config.rs's release arm (Task 3) and into server/webhook/.env.
KEYGEN_ACCOUNT_ID="$(uuidgen | tr 'A-Z' 'a-z')"

# Admin user created by the non-interactive `rails keygen:setup` one-shot.
KEYGEN_ADMIN_EMAIL=admin@tinkerdev.io
KEYGEN_ADMIN_PASSWORD="$(openssl rand -hex 16)"

# Public production host (two-label — no KEYGEN_DOMAIN single-label workaround
# needed, but set both correctly per Pitfall 4).
KEYGEN_HOST=license.tinkerdev.io
KEYGEN_DOMAIN=license.tinkerdev.io

# --- Caddy real-ACME front (Pitfall 3) ---
# CADDY_HOSTS is the public host Caddy serves + requests a Let's Encrypt cert
# for; CADDY_ACME_EMAIL is a REAL address for the ACME account + expiry notices.
CADDY_HOSTS=license.tinkerdev.io
CADDY_ACME_EMAIL=alerts@tinkerdev.io
