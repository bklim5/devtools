{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TinkerDev",
  "version": "0.3.2",
  "identifier": "com.tinkerdev.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TinkerDev",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "theme": "Dark",
        "visible": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://github.com https://objects.githubusercontent.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-",
      "hardenedRuntime": true,
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk3OEY5QUVGNjZFMUI2OUEKUldTYXR1Rm03NXFQbHpGeHVCQ1hKUkV6WXlJR0RKZENIbmFCUkR5dkk2cS9VTndVSGU4eFVCZzQK",
      "endpoints": [
        "https://github.com/bklim5/devtools-releases/releases/latest/download/latest.json"
      ]
    }
  }
}
