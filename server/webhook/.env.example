# TinkerDev purchase-webhook backend — secret TEMPLATE (D-55/D-41).
# Copy to `server/webhook/.env` (gitignored) and fill REAL values on the VPS.
# NEVER commit real values. The backend reaches Keygen CE over localhost only.

# --- Keygen CE (privileged admin token — server-side ONLY, never in the app) ---
KEYGEN_HOST=localhost
KEYGEN_ACCOUNT_ID=
KEYGEN_ADMIN_TOKEN=
KEYGEN_POLICY_ID=

# --- Lemon Squeezy (Merchant of Record, D-61) ---
# Store webhook signing secret — used to HMAC-verify the raw request body (D-60).
LS_WEBHOOK_SECRET=

# --- Resend (transactional key email, D-64/D-66) ---
RESEND_API_KEY=
EMAIL_FROM=TinkerDev Licenses <licenses@tinkerdev.io>

# --- HTTP server ---
PORT=8787
