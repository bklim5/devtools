# TinkerDev purchase-webhook backend — secret TEMPLATE (D-55/D-41).
# Copy to `server/webhook/.env` (gitignored) and fill REAL values on the VPS.
# NEVER commit real values. The backend reaches Keygen CE over localhost only.

# --- Keygen CE (privileged admin token — server-side ONLY, never in the app) ---
# Keygen forces HTTPS + the canonical Host (= KEYGEN_HOST), so the webhook MUST
# use the PUBLIC https origin. An internal http://web:3000 fails: keygen 301s
# http→https and returns 403 on the wrong Host. On the box this URL resolves to
# the box's OWN public IP, so the request stays on-host (loopback) over TLS — the
# admin token still never crosses the public internet (D-55). Local dev uses the
# local CE origin instead (e.g. https://localhost behind Caddy).
KEYGEN_BASE_URL=https://license.tinkerdev.io
KEYGEN_ACCOUNT_ID=
KEYGEN_ADMIN_TOKEN=
KEYGEN_POLICY_ID=

# --- Lemon Squeezy (Merchant of Record, D-61) ---
# Store webhook signing secret — used to HMAC-verify the raw request body (D-60).
LS_WEBHOOK_SECRET=

# --- Resend (transactional key email, D-64/D-66) ---
# Verified sending domain is email.tinkerdev.io (DKIM/SPF live under that
# subdomain), so the From address MUST be @email.tinkerdev.io.
RESEND_API_KEY=
EMAIL_FROM=TinkerDev Licenses <licenses@email.tinkerdev.io>
# Reply-To: a MONITORED inbox (M365 on tinkerdev.io) so buyer replies reach you.
# The send domain (email.tinkerdev.io) has no inbox; this routes replies elsewhere.
EMAIL_REPLY_TO=licenses@tinkerdev.io

# --- HTTP server ---
PORT=8787
